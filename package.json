{
  "name": "socos",
  "description": "Social Operating System - Gamified, Agent-First Personal CRM",
  "version": "0.1.0",
  "private": true,
  "author": "yevgeniusr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nanachichan3/socos.git"
  },
  "bugs": {
    "url": "https://github.com/nanachichan3/socos/issues"
  },
  "homepage": "https://github.com/nanachichan3/socos#readme",
  "keywords": [
    "monorepo",
    "typescript",
    "nextjs",
    "react",
    "nestjs",
    "turborepo",
    "pnpm",
    "personal-crm",
    "gamification",
    "ai-agents"
  ],
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "type:check": "turbo run type:check",
    "build": "turbo run build --force",
    "build:backend": "turbo run build --filter=*backend",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "prettier-plugin-jsdoc": "^1.3.0",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
