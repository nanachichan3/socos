# ===========================================
# SOCOS API - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/socos?schema=public"

# App
APP_URL="https://socos.app"
NODE_ENV="development"

# ===========================================
# AI AGENTS
# ===========================================
# OpenAI API for AI-powered summaries and enrichment
OPENAI_API_KEY="sk-..."

# Anthropic API (optional - for Claude)
ANTHROPIC_API_KEY="sk-ant-..."

# ===========================================
# EMAIL - Resend
# ===========================================
# Sign up at https://resend.com
# Resend is a modern email API that's simple to use
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="SOCOS <noreply@socos.app>"

# ===========================================
# SMS - Twilio
# ===========================================
# Sign up at https://www.twilio.com
# Twilio provides reliable SMS delivery globally
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"

# ===========================================
# JWT (for authentication)
# ===========================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ===========================================
# Optional: External Services
# ===========================================

# Clearbit (for contact enrichment)
CLEARBIT_API_KEY="..."

# LinkedIn API (for professional info)
LINKEDIN_CLIENT_ID="..."
LINKEDIN_CLIENT_SECRET="..."

# Google Calendar (for calendar integration)
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."

# Cal.com (for meeting scheduling)
CAL_COM_API_KEY="..."
