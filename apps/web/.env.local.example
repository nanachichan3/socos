# SOCOS Web Environment Variables
# Copy this file to .env.local and fill in the values

# ──────────────────────────────────────────────────
# NEXTAUTH (Required)
# ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# ──────────────────────────────────────────────────
# SOCOS API (Required for production)
# ──────────────────────────────────────────────────
# URL of the SOCOS Express API (default: http://localhost:3001 for local dev)
SOCOS_API_URL=http://localhost:3001
